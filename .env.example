# Copy to .env at REPO ROOT (same folder as README.md):
#   cp .env.example .env
#
# Path on disk:
#   /home/trung/Documents/2026/project/DeFi-powered/.env
#
# Pydantic loads this via LIVELEAD_ prefix (see src/livelead/runtime/settings.py).

LIVELEAD_ENVIRONMENT=development
LIVELEAD_SQLITE_PATH=data/livelead.sqlite3
LIVELEAD_REDIS_URL=redis://127.0.0.1:6379/0

# Real browser sessions (US-020) — use system Chrome if Playwright bundled chromium is missing
LIVELEAD_BROWSER_AUTOMATION_MODE=playwright
LIVELEAD_BROWSER_HEADLESS=true
LIVELEAD_PLAYWRIGHT_CHROMIUM_EXECUTABLE=/usr/bin/google-chrome-stable
LIVELEAD_DISCOVERY_USE_MOCK_CONNECTORS=false

# CloakBrowser (when connector automation_engine is cloakbrowser)
LIVELEAD_CLOAKBROWSER_EXECUTABLE=/usr/local/bin/cloakbrowser

# Alternative: scripts/playwright-install.sh writes (auto-loaded at API startup):
#   frontend/.playwright-browser.env  →  PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=...