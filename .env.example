# =============================================================================
# LiveLead — environment template (repo root)
# =============================================================================
# Copy to .env at REPO ROOT (same folder as README.md):
#   cp .env.example .env
#
# All application settings use the LIVELEAD_ prefix and are loaded by
# src/livelead/runtime/settings.py (Pydantic). Workers and schedulers also
# read repo-root .env via src/livelead/runtime/env_bootstrap.py.
#
# Optional (not LIVELEAD_): frontend/.playwright-browser.env is auto-loaded
# after .env when produced by scripts/playwright-install.sh
# =============================================================================

# --- Core runtime ---
# development | staging | production (label only for logs/diagnostics)
LIVELEAD_ENVIRONMENT=development

# SQLite database file (Alembic + API + worker)
LIVELEAD_SQLITE_PATH=data/livelead.sqlite3

# Dramatiq broker / Redis (discovery jobs, notifications queue)
LIVELEAD_REDIS_URL=redis://127.0.0.1:6379/0

# API bind (when starting uvicorn manually; scripts may override)
LIVELEAD_API_HOST=127.0.0.1
LIVELEAD_API_PORT=8000

# Fernet key for encrypting connector secrets at rest — CHANGE IN PRODUCTION
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LIVELEAD_SECRET_MASTER_KEY=dev-only-change-in-production-livelead

# --- Identity & access (US-027) ---
# Session cookie lifetime (seconds)
LIVELEAD_AUTH_SESSION_TTL_SECONDS=28800

# Set true when API is served only over HTTPS
LIVELEAD_AUTH_COOKIE_SECURE=false

# Legacy X-Actor-Role / X-Organization-Id without login — true for local dev/tests;
# set false in production behind real auth
LIVELEAD_AUTH_ALLOW_DEV_HEADERS=true

# Bootstrap owner (created on first DB init if missing)
LIVELEAD_AUTH_DEFAULT_OWNER_EMAIL=owner@example.com
LIVELEAD_AUTH_DEFAULT_OWNER_PASSWORD=Owner-Pass-2026
LIVELEAD_AUTH_DEFAULT_OWNER_NAME=LiveLead Owner
LIVELEAD_AUTH_DEFAULT_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001

# Login rate limit (failed attempts per window → lockout)
LIVELEAD_AUTH_RATE_LIMIT_THRESHOLD=5
LIVELEAD_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LIVELEAD_AUTH_RATE_LIMIT_LOCKOUT_SECONDS=900

# --- Discovery jobs & connectors ---
# false = real RSS/API/browser connectors; true = deterministic mocks (CI/tests only)
LIVELEAD_DISCOVERY_USE_MOCK_CONNECTORS=false

# Playwright e2e fixtures (do not enable in production)
LIVELEAD_EXPOSE_E2E_DISCOVERY_RSS_FIXTURE=false
LIVELEAD_EXPOSE_E2E_DISCOVERY_WEBSITE_FIXTURE=false

# --- Discovery copilot (US-037) — Google AI Studio ---
# deterministic = local template (tests/CI); gemini = requires API key below
LIVELEAD_DISCOVERY_COPILOT_PROVIDER=gemini
# API key: https://aistudio.google.com/apikey
LIVELEAD_GOOGLE_AI_STUDIO_API_KEY=
LIVELEAD_GEMINI_MODEL=gemini-2.0-flash
# google-genai is included in pip install -e ".[dev]" / default project deps

# --- Browser automation (US-020+) ---
# playwright | cloakbrowser | stub (stub = tests only, no Chromium)
LIVELEAD_BROWSER_AUTOMATION_MODE=playwright
LIVELEAD_BROWSER_HEADLESS=true
LIVELEAD_BROWSER_NAVIGATION_TIMEOUT_MS=45000

# System Chrome/Chromium path (if Playwright bundled browser is missing)
LIVELEAD_PLAYWRIGHT_CHROMIUM_EXECUTABLE=/usr/bin/google-chrome-stable

# Isolated profile storage and debug artifact root
LIVELEAD_BROWSER_PROFILE_ROOT=data/browser_profiles
LIVELEAD_ARTIFACT_ROOT=data

# --- CloakBrowser policy (US-025) — when connector automation_engine is cloakbrowser ---
LIVELEAD_CLOAKBROWSER_EXECUTABLE=/usr/local/bin/cloakbrowser
LIVELEAD_CLOAKBROWSER_KILL_SWITCH=false
LIVELEAD_CLOAKBROWSER_PINNED_VERSION=
LIVELEAD_CLOAKBROWSER_RUNTIME_VERSION=
LIVELEAD_CLOAKBROWSER_EXPECTED_CHECKSUM=
LIVELEAD_CLOAKBROWSER_RUNTIME_CHECKSUM=

# --- Discovery schedule scheduler (apps/scheduler/main.py) ---
# once = single tick (default for verify scripts); loop = run forever
LIVELEAD_SCHEDULER_MODE=once
LIVELEAD_SCHEDULER_INTERVAL_SEC=60

# --- Observability (optional hooks; not fully wired in Foundation) ---
LIVELEAD_OTEL_ENABLED=false
LIVELEAD_SENTRY_DSN=

# --- Tests / local overrides (optional) ---
# LIVELEAD_BROWSER_LIVE_TEST=1          # run real Playwright integration tests
# LIVELEAD_DISCOVERY_COPILOT_PROVIDER=deterministic  # copilot without Gemini key